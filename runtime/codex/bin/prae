#!/usr/bin/env bash
# prae — PRAE unified CLI entrypoint (Codex version)
#
# See bin/README.md for installation instructions
# Usage: prae <subcommand> [args...]
#
# Subcommands:
#   bootstrap                     deploy PRAE to the current project
#   init                          initialize the research project (generate the registry and Phase 0 artifacts)
#   add-track <track_id>          formally register a new track into the registry
#   new-track <track_id>          create the current-phase directory for an already-registered track
#   new-exp <track_id>            create a new experiment
#   record-result <track_id> <exp_id>  record an experiment result
#   lock-infra <track_id>         formally lock an infrastructure track
#   update-track-state <track_id> <state>  formally update a research track state
#   advance-phase                 generate the phase gate report the first time; once approved, formally advance the phase
#   graduate <track_id>           graduate a research track to PDAE
#   finalize                      record the project's terminal decision
#   reopen                        reopen to Phase 1 based on a CONTINUE decision

set -euo pipefail

PRAE_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PRAE_ROOT="$(cd "${PRAE_BIN_DIR}/../.." && pwd)"
TASKS_DIR="${PRAE_ROOT}/runtime/codex/tasks"

SUBCOMMAND="${1:-help}"
shift || true

case "${SUBCOMMAND}" in
  bootstrap)
    exec codex exec --task "${TASKS_DIR}/prae-bootstrap.md" -- "$@"
    ;;
  init)
    exec codex exec --task "${TASKS_DIR}/prae-init.md" -- "$@"
    ;;
  add-track)
    [ -n "${1:-}" ] || { echo "Error: please provide a track_id"; echo "Usage: prae add-track <track_id> --type <research|infrastructure> [...]"; exit 1; }
    exec codex exec --task "${TASKS_DIR}/prae-add-track.md" -- "$@"
    ;;
  new-track)
    [ -n "${1:-}" ] || { echo "Error: please provide a track_id"; echo "Usage: prae new-track <track_id>"; exit 1; }
    exec codex exec --task "${TASKS_DIR}/prae-new-track.md" -- "$@"
    ;;
  new-exp)
    [ -n "${1:-}" ] || { echo "Error: please provide a track_id"; echo "Usage: prae new-exp <track_id>"; exit 1; }
    exec codex exec --task "${TASKS_DIR}/prae-new-exp.md" -- "$@"
    ;;
  record-result)
    [ -n "${1:-}" ] && [ -n "${2:-}" ] || {
      echo "Error: please provide a track_id and an exp_id"
      echo "Usage: prae record-result <track_id> <exp_id>"
      exit 1
    }
    exec codex exec --task "${TASKS_DIR}/prae-record-result.md" -- "$@"
    ;;
  lock-infra)
    [ -n "${1:-}" ] || {
      echo "Error: please provide an infrastructure track_id"
      echo "Usage: prae lock-infra <track_id> --approver <name> --reason <reason> [--contracts <path>] [--module-spec <path>]"
      exit 1
    }
    exec codex exec --task "${TASKS_DIR}/prae-lock-infra.md" -- "$@"
    ;;
  update-track-state)
    [ -n "${1:-}" ] && [ -n "${2:-}" ] || {
      echo "Error: please provide a track_id and a to_state"
      echo "Usage: prae update-track-state <track_id> <ACTIVE|KILLED|MERGED|GRADUATED> --approver <name> --reason <reason>"
      exit 1
    }
    exec codex exec --task "${TASKS_DIR}/prae-update-track-state.md" -- "$@"
    ;;
  advance-phase)
    exec codex exec --task "${TASKS_DIR}/prae-advance-phase.md" -- "$@"
    ;;
  graduate)
    [ -n "${1:-}" ] || { echo "Error: please provide a track_id"; echo "Usage: prae graduate <track_id>"; exit 1; }
    exec codex exec --task "${TASKS_DIR}/prae-graduate.md" -- "$@"
    ;;
  finalize)
    exec codex exec --task "${TASKS_DIR}/prae-finalize.md" -- "$@"
    ;;
  reopen)
    exec codex exec --task "${TASKS_DIR}/prae-reopen.md" -- "$@"
    ;;
  help|--help|-h)
    cat << 'HELP'
prae — PRAE Research Methodology CLI (Codex version)

Usage:
  prae bootstrap                      deploy PRAE to the current project (first use)
  prae init                           initialize the research project (run after filling in PRAE_INIT.md; generates the registry and Phase 0 artifacts)
  prae add-track <track_id>           formally register a new track into track_registry.yaml
  prae new-track <track_id>           create the current-phase directory and initial log for an already-registered track
  prae new-exp <track_id>             create a new experiment record and code skeleton
  prae record-result <id> <exp_id>    record an experiment result into TRACK_LOG.md
  prae lock-infra <id>                formally update an infrastructure track to LOCKED after human approval
  prae update-track-state <id> <state>  formally update a research track state after human approval
  prae advance-phase                  generate the phase gate analysis the first time; once approved, verify the gate and formally advance
  prae graduate <track_id>            graduate a research track to a PDAE engineering project
  prae finalize                       record the project's terminal decision
  prae reopen                         reopen to Phase 1 based on a CONTINUE decision

Examples:
  prae bootstrap
  # after filling in prae/PRAE_INIT.md
  prae init
  # to add a track that has not yet been registered, register it first
  prae add-track research_strategy_reversal --type research --hypothesis "The reversal factor works on A-share ETFs" --depends-on infra_data_v1
  # Phase 0: infrastructure selection / PDAE M1-M3 / lock
  prae new-track infra_data_v1
  prae new-exp infra_data_v1 --title "DuckDB selection experiment"
  prae record-result infra_data_v1 EXP_001
  prae lock-infra infra_data_v1 --approver saionji --reason "PDAE M3 passed"
  prae advance-phase
  # after a human writes APPROVED: yes in PHASE_GATE.md
  prae advance-phase
  # Phase 1: research track exploration
  prae new-track research_strategy_momentum
  prae new-exp research_strategy_momentum
  prae record-result research_strategy_momentum EXP_003
  prae update-track-state research_strategy_momentum ACTIVE --approver saionji --reason "EXP_003 positive signal"
  prae advance-phase
  # after a human writes APPROVED: yes in PHASE_GATE.md
  prae advance-phase
  prae graduate research_strategy_momentum
  prae finalize
  prae reopen

Documentation: PRAE_ROOT/methodology/PRAE_QUICKSTART.md
HELP
    exit 0
    ;;
  *)
    echo "Unknown subcommand: ${SUBCOMMAND}"
    echo "Run 'prae help' for usage"
    exit 1
    ;;
esac
